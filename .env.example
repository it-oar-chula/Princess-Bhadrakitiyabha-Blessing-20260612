APP_TITLE=ร่วมลงนามถวายความอาลัย
ADMIN_CODE=change-me
DB_PATH=data/signatures.db
EXPORT_BASENAME=20260612-Bhadrakitiyabha-Blessing
# พอร์ตบนเครื่อง host -> container (8000). บน server ที่ 8000 ไม่ว่าง ให้ตั้งเป็น 8088
HOST_PORT=8000
# กันกดรัวทั้งระบบ: submit ใหม่ได้ทุกกี่วินาที
SUBMISSION_COOLDOWN_SECONDS=8
# จำกัดต่อ client/IP: ภายใน 1 นาที ส่งได้ไม่เกินกี่ครั้ง
SUBMISSION_MAX_PER_MINUTE=6
